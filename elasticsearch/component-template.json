{
  "template": {
    "settings": {
      "index.lifecycle.name": "web-analytics-ilm-policy"
    },
    "mappings": {
      "dynamic": false,
      "properties": {
        "@timestamp": { "type": "date" },
        "received_at": { "type": "date" },
        "type": { "type": "keyword" },
        "site_id": { "type": "keyword" },
        "session_id": { "type": "keyword" },
        "anonymous_id": { "type": "keyword" },
        "user_id": { "type": "keyword" },
        "path": { "type": "keyword" },
        "url": { "type": "wildcard" },
        "referrer": { "type": "wildcard" },
        "title": {
          "type": "text",
          "fields": {
            "keyword": { "type": "keyword", "ignore_above": 256 }
          }
        },
        "request_domain": { "type": "keyword" },
        "request_host": { "type": "keyword" },
        "client_ip": { "type": "ip", "ignore_malformed": true },
        "geo_country_iso_code": { "type": "keyword" },
        "geo_country_name": { "type": "keyword" },
        "geo_city_name": { "type": "keyword" },
        "geo_location": { "type": "geo_point", "ignore_malformed": true },
        "forwarded_for": { "type": "wildcard" },
        "user_agent": { "type": "wildcard" },
        "browser_family": { "type": "keyword" },
        "browser_version": { "type": "keyword" },
        "browser_major": { "type": "keyword" },
        "browser_engine": { "type": "keyword" },
        "os_family": { "type": "keyword" },
        "os_version": { "type": "keyword" },
        "device_family": { "type": "keyword" },
        "device_brand": { "type": "keyword" },
        "device_model": { "type": "keyword" },
        "device_type": { "type": "keyword" },
        "accept_language": { "type": "keyword" },
        "accept_language_primary_tag": { "type": "keyword" },
        "accept_language_primary_base": { "type": "keyword" },
        "accept_language_primary_region": { "type": "keyword" },
        "accept_language_tags": { "type": "keyword" },
        "timezone": { "type": "keyword" },
        "timezone_area": { "type": "keyword" },
        "timezone_location": { "type": "keyword" },
        "timezone_offset_minutes": { "type": "short" },
        "origin": { "type": "wildcard" },
        "referer_header": { "type": "wildcard" },
        "scheme": { "type": "keyword" },
        "remote_addr": { "type": "keyword" },
        "collector_version": { "type": "keyword" },
        "traffic_quality": { "type": "keyword" },
        "is_suspect": { "type": "boolean" },
        "suspicion_reasons": { "type": "keyword" },
        "conversation_id": { "type": "keyword" },
        "turn_index": { "type": "integer" },
        "locale": { "type": "keyword" },
        "consent_state": { "type": "keyword" },
        "conversation_stage": { "type": "keyword" },
        "actor": { "type": "keyword" },
        "message_role": { "type": "keyword" },
        "message_format": { "type": "keyword" },
        "response_kind": { "type": "keyword" },
        "source": { "type": "keyword" },
        "action_type": { "type": "keyword" },
        "has_read_more": { "type": "boolean" },
        "has_suggestions": { "type": "boolean" },
        "initiated_by": { "type": "keyword" },
        "navigation_source": { "type": "keyword" },
        "destination_title": { "type": "keyword" },
        "destination_href": { "type": "wildcard" },
        "payload": { "type": "flattened" }
      }
    }
  }
}
