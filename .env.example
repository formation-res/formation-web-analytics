ALLOWED_DOMAINS=analytics.tryformation.com
CADDY_DOMAINS=analytics.tryformation.com
ELASTICSEARCH_URL=https://elasticsearch:9200
ELASTICSEARCH_API_KEY=changeme
ELASTICSEARCH_DATA_STREAM=analytics-events
MAXMIND_ACCOUNT_ID=your-account-id
MAXMIND_LICENSE_KEY=your-license-key
GEOIPUPDATE_EDITION_IDS=GeoLite2-City
GEOIPUPDATE_FREQUENCY=24
GEOIPUPDATE_VERBOSE=0
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb
GEOIP_WAIT_TIMEOUT=300
LISTEN_ADDR=:8080
METRICS_ENABLED=false
METRICS_LISTEN_ADDR=:9090
FLUSH_INTERVAL=5s
MAX_BATCH_SIZE=500
MAX_QUEUE_SIZE=10000
MAX_PAYLOAD_BYTES=1048576
MAX_EVENTS_PER_REQUEST=100
MAX_FIELD_LENGTH=2048
MAX_PAYLOAD_ENTRIES=128
MAX_PAYLOAD_DEPTH=4
MAX_RETRIES=10
RETRY_MIN_BACKOFF=1s
RETRY_MAX_BACKOFF=60s
TRUST_PROXY_HEADERS=true
CAPTURE_CLIENT_IP=false
DROP_POLICY=reject
LOG_LEVEL=info
RETENTION_DAYS=90
READ_TIMEOUT=10s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s
